      m_Calls: []
  m_text: "In this meter bridge simulation, the interchange of the resistance box
    between the left and right gaps is detected using two separate trigger colliders
    placed at the left and right gaps of the bridge. Each gap has a GapDetector script
    attached, which activates when the resistance box enters its collider. If the
    box enters the right gap collider, the system applies the balance length formula
    \n\U0001D459\n=\n100\n\U0001D445\n\U0001D445\n+\n\U0001D44B"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
