  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: 'The maximum weight that can be weighed on an analytical balance is the
    sum of all the weights, fractional weights and weight of the rider provided with
    the analytical balance.


    (i) Sum of all the weights = (100+50+20+20+10+5+2+2+1)
    g = 210g


    (ii) Sum of all the fractional weights =(500+200+200+100+50+20+20+10)
    mg = 1100 mg = 1.1g


    (iii) Max. weight of the rider = 10 mg = 0.01 g


    Therefore,
    the maximum weight that can be weighed on an analytical balance = 210+ 1.1+0.01
    = 211.11 g

'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 356b1ee212a194b49bed1adb63017c1b, type: 2}
  m_sharedMaterial: {fileID: -8232536831469020223, guid: 356b1ee212a194b49bed1adb63017c1b, type: 2}
