  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: 'Moving the rider to the right side of the zero adds weight to the weight
    on the right pan, whereas moving the rider to the left side deducts weight from
    the weight on the right pan.


    Total weight by rider placed at 2.1 mark =
    (2x 1 mg) +(1x0.2 mg) = 2.2 mg.


    Since the rider is on the left side of
    the beam, 2.2 mg gets subtracted from the weight on the right pan.'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 356b1ee212a194b49bed1adb63017c1b, type: 2}
  m_sharedMaterial: {fileID: -8232536831469020223, guid: 356b1ee212a194b49bed1adb63017c1b, type: 2}
