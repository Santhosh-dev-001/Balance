  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: 'Let''s understand the calculations of weight added by the rider.


    The
    weight of the rider is 10 mg and the graduated beam is divided into 10 equal
    divisions on both sides of the central mark.


    So

    Weight of each big
    division = 10 mg/10 = 1 mg 2m

    Weight of each small division = 1 mg/5 = 0.2
    mg

'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 356b1ee212a194b49bed1adb63017c1b, type: 2}
